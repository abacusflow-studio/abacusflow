{
  "name": "abacusflow-apps",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate": "npm run generate:core",
    "generate:core": "npm run generate -w @abacusflow/core",
    "dev:web": "npm run dev -w abacusflow-web",
    "dev:mobile": "npm run start -w abacusflow-mobile -- --tunnel",
    "dev:mobile:android": "npm run android -w abacusflow-mobile -- --tunnel",
    "dev:mobile:ios": "npm run ios -w abacusflow-mobile -- --tunnel",
    "dev:mobile:web": "npm run web -w abacusflow-mobile -- --tunnel",
    "dev:desktop": "npm run start -w abacusflow-desktop",
    "build": "npm run build:web",
    "build:web": "npm run build -w abacusflow-web",
    "build:web:turbopack": "npm run build-turbopack -w abacusflow-web",
    "build:desktop": "npm run build -w abacusflow-desktop",
    "build:all": "npm run build -ws --if-present",
    "lint:web": "npm run lint -w abacusflow-web",
    "lint:core": "npm run lint -w @abacusflow/core",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "format": "prettier --write .",
    "clean": "npm run clean -ws --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
