    "clean": "npm run clean -ws --if-present"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3"
  }
}
