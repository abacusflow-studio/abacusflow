# Auth0 Configuration
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://admin.abacusflow.cn
# Optional. Defaults to the current origin + /callback.
# NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/callback

# Local development API proxy target for Next.js rewrites.
# API_PROXY_TARGET=http://localhost:8080

# App Version (optional)
# NEXT_PUBLIC_APP_VERSION=0.0.3
