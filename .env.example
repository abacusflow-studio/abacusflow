POSTGRES_VERSION=15
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=passwd

CUBE_VERSION=v1.3


ABACUSFLOW_SERVER_VERSION=latest
ABACUSFLOW_SERVER_HOST=abacusflow-server
ABACUSFLOW_SERVER_PORT=8080

ABACUSFLOW_CUBE_HOST=cube
ABACUSFLOW_CUBE_PORT=4000

ABACUSFLOW_WEBAPP_VERSION=latest
ABACUSFLOW_WEBAPP_HTTP_PORT=5173
ABACUSFLOW_WEBAPP_HTTPS_PORT=5174

# ========================
# Supabase S3 兼容存储
# ========================
# 在 Supabase Dashboard → Project Settings → Storage → S3 Access Keys 获取
S3_ENDPOINT=https://<your-project-ref>.supabase.co/storage/v1/s3
S3_BUCKET=feedback
S3_ACCESS_KEY=<your-supabase-s3-access-key>
S3_SECRET_KEY=<your-supabase-s3-secret-key>
S3_REGION=us-east-1
